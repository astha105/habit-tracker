rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    // A user can only read/write their own profile.
    // All writes that matter go through Cloud Functions (admin SDK bypasses rules).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Profile creation handled by createOrUpdateProfile Cloud Function (admin SDK).
      // Deny direct client writes to prevent tampering with the premium flag.
      allow write: if false;

      // ── Habits ───────────────────────────────────────────────────────────────
      // Clients read and write habits directly; premium flag lives on the user
      // doc (write: false above) so it cannot be tampered with from the client.
      match /habits/{habitId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── Stats ────────────────────────────────────────────────────────────────
      // Written by the client after every habit save/log. Read-only for stats UI.
      match /stats/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── AI Cache ─────────────────────────────────────────────────────────────
      match /aiCache/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ── Coach History ─────────────────────────────────────────────────────────
      match /coachHistory/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    // Written only by the Razorpay webhook (admin SDK). Never readable by clients.
    match /payments/{docId} {
      allow read, write: if false;
    }

    // ── Partnerships ──────────────────────────────────────────────────────────
    // Client-side: owner creates, partner accepts (one-time update), both read.
    match /partnerships/{partnershipId} {
      // Both parties can read their own partnerships
      allow read: if request.auth != null &&
        (resource.data.ownerUid == request.auth.uid ||
         resource.data.partnerUid == request.auth.uid);
      // Owner can create a new pending partnership
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Partner can accept: sets their uid + name + status=active only
      allow update: if request.auth != null &&
        resource.data.status == 'pending' &&
        resource.data.partnerUid == null &&
        request.resource.data.partnerUid == request.auth.uid &&
        request.resource.data.status == 'active' &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;
    }

    // ── Nudges ────────────────────────────────────────────────────────────────
    // Any authenticated user can create a nudge (from themselves).
    // Only the target user can read/update (mark seen) their own nudges.
    match /nudges/{nudgeId} {
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow read, update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
